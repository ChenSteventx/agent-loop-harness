{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-loop-harness.invalid/schemas/explorer-output.schema.json",
  "title": "ExplorerOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "relevantFiles",
    "likelyAffectedTests",
    "evidence",
    "importantUnknowns"
  ],
  "properties": {
    "relevantFiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "symbols"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          },
          "symbols": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300
            },
            "maxItems": 100
          }
        }
      },
      "maxItems": 200
    },
    "likelyAffectedTests": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024
      },
      "maxItems": 200
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "observation"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          },
          "observation": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          }
        }
      },
      "maxItems": 200
    },
    "importantUnknowns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2000
      },
      "maxItems": 100
    }
  }
}
