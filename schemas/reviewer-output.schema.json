{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-loop-harness.invalid/schemas/reviewer-output.schema.json",
  "title": "ReviewerOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "findings"
  ],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "category",
          "severity",
          "claim",
          "location",
          "verificationRequest",
          "evidenceIds",
          "confidence",
          "proposedVerification",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "category": {
            "type": "string",
            "enum": [
              "correctness",
              "acceptance",
              "security",
              "reliability",
              "test",
              "maintainability"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "claim": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4000
          },
          "location": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          },
          "verificationRequest": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "verificationStepId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                  },
                  "proposedArgv": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "maxLength": 1024
                    },
                    "maxItems": 32
                  },
                  "expectedExitCode": {
                    "type": "integer"
                  },
                  "stdoutIncludes": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 2000
                  },
                  "stderrIncludes": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 2000
                  }
                }
              },
              {
                "type": "null"
              }
            ]
          },
          "evidenceIds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "maxItems": 50
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "proposedVerification": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          },
          "status": {
            "type": "string",
            "const": "proposed"
          }
        }
      },
      "maxItems": 100
    }
  }
}
