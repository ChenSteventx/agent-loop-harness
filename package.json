{
  "name": "agent-loop-harness",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "KISS evidence-driven harness for coding agents",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "node automation/setup.mjs",
    "loop": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm test",
    "codex:phase1": "node automation/continue.mjs phase-1",
    "codex:phase2": "node automation/continue.mjs phase-2",
    "codex:phase3": "node automation/continue.mjs phase-3",
    "codex:status": "node automation/status.mjs"
  },
  "dependencies": {
    "better-sqlite3": "latest",
    "commander": "latest",
    "yaml": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
